{
  "manifest_version": 3,
  "name": "Kaizen",
  "version": "1.0.0",
  "description": "anything that distracts is evil, destroy evil",
  "permissions": ["storage", "tabs"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "options_page": "options.html",
  "action": {
    "default_title": "Kaizen",
    "default_popup": "popup.html",
    "default_icon": "kaizen-logo.png"
  },
  "icons": {
    "128": "kaizen-logo.png"
  }
}
